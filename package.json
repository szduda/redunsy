{
  "name": "redunsy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-search-index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "jakis-problem": "tsc --noEmit && npm test && npm run lint:fix && npm run format",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:playback": "vitest run features/groovy-player/playback.test.ts features/groovy-player/swing-pattern.test.ts lib/midinike/groove/playback-groove.test.ts lib/midinike/groove/playback-tempo.test.ts lib/midinike/groove/compile-groove.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/firestore-migration/seed-rhythms.ts",
    "telegram:extract": "tsx scripts/telegram-export-migration/extract.ts",
    "telegram:seed": "tsx scripts/telegram-export-migration/seed-rhythms.ts",
    "search-index": "tsx scripts/generate-search-index.ts",
    "search-index:bootstrap": "tsx scripts/firestore-migration/bootstrap-search-index.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.4.2",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/config": "^0.5.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "happy-dom": "^20.10.6",
    "lz-string": "^1.5.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
